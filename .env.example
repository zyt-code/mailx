# Windows Code Signing Configuration
# Copy this file to .env and fill in your actual values

# Code Signing Certificate (PFX format)
WINDOWS_SIGNING_CERTIFICATE_PATH=C:\path\to\your\certificate.pfx
WINDOWS_SIGNING_CERTIFICATE_PASSWORD=your_certificate_password

# Timestamp Server (required for timestamping signatures)
# Recommended: Use public timestamp servers or your own
WINDOWS_TIMESTAMP_SERVER=http://timestamp.digicert.com
# Alternative: http://timestamp.sectigo.com
# Alternative: http://timestamp.globalsign.com

# Windows Store / MSIX Publishing
# These values are used for MSIX package generation
WINDOWS_STORE_PUBLISHER_ID=CN=YourPublisherName
WINDOWS_STORE_PUBLISHER_DISPLAY_NAME=Your Publisher Name

# Optional: Skip signing during development
# Set to 'true' to disable code signing (NOT for production)
WINDOWS_SKIP_SIGNING=false

# Tauri Environment
TAURI_PRIVATE_KEY=path/to/your/key.pem
TAURI_KEY_PASSWORD=your_key_password
